# Copy to .env and fill in. Agentloom reads these at startup.

# --- Provider keys ---
VOLCENGINE_API_KEY=
TAVILY_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# --- App overrides (rarely needed in dev) ---
AGENTLOOM_ENVIRONMENT=dev
AGENTLOOM_LOG_LEVEL=INFO
AGENTLOOM_DATABASE_URL=postgresql+asyncpg://agentloom:agentloom@localhost:5432/agentloom
AGENTLOOM_REDIS_URL=redis://localhost:6379/0
